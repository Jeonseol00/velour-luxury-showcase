---
import OlfactoryOracle from './OlfactoryOracle.jsx';
---

<section class="oracle" id="oracle" aria-label="Olfactory Oracle scent quiz">
  <div class="container">
    <div class="oracle__header reveal-on-scroll">
      <span class="oracle__label">The Oracle</span>
      <h2 class="oracle__title">Your Scent, Decoded</h2>
      <p class="oracle__subtitle">
        Answer five questions. Let our Olfactory Oracle map your invisible identity
        and reveal the fragrance written in your DNA.
      </p>
    </div>

    <OlfactoryOracle client:visible />
  </div>
</section>
