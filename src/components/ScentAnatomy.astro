---
---

<section class="anatomy" id="anatomy" aria-label="Scent anatomy">
  <div class="container">
    <div class="anatomy__inner">
      <div class="anatomy__text-col reveal-on-scroll-left">
        <span class="anatomy__label">The Craft</span>
        <h2 class="anatomy__heading">The Architecture of Fragrance</h2>
        <p class="anatomy__desc">
          Every VELOUR composition unfolds in three acts across your skin. The opening — bright, arresting,
          demanding attention. The heart — complex, intimate, revealing character. The base — deep, lingering,
          the part that people remember when you've left the room.
        </p>
        <p class="anatomy__desc">
          Our perfumers orchestrate up to 120 raw materials into a single composition,
          balancing volatility curves with molecular weight to ensure each note
          transitions seamlessly over 8 to 12 hours of wear.
        </p>
      </div>

      <div class="anatomy__pyramid reveal-on-scroll-right" role="list" aria-label="Fragrance pyramid">
        <!-- Top Notes -->
        <div class="pyramid-layer" role="listitem">
          <h3 class="pyramid-layer__title">Top Notes</h3>
          <p class="pyramid-layer__time">First 15 minutes</p>
          <div class="pyramid-layer__notes">
            <span class="note-pill">Bergamot</span>
            <span class="note-pill">Pink Pepper</span>
            <span class="note-pill">Yuzu</span>
            <span class="note-pill">Saffron</span>
          </div>
        </div>

        <!-- Heart Notes -->
        <div class="pyramid-layer" role="listitem">
          <h3 class="pyramid-layer__title">Heart Notes</h3>
          <p class="pyramid-layer__time">1 — 4 hours</p>
          <div class="pyramid-layer__notes">
            <span class="note-pill">Rose Absolute</span>
            <span class="note-pill">Iris</span>
            <span class="note-pill">Jasmine</span>
            <span class="note-pill">Oud</span>
            <span class="note-pill">Leather</span>
          </div>
        </div>

        <!-- Base Notes -->
        <div class="pyramid-layer" role="listitem">
          <h3 class="pyramid-layer__title">Base Notes</h3>
          <p class="pyramid-layer__time">4 — 12 hours</p>
          <div class="pyramid-layer__notes">
            <span class="note-pill">Amber</span>
            <span class="note-pill">Sandalwood</span>
            <span class="note-pill">Vanilla</span>
            <span class="note-pill">Musk</span>
            <span class="note-pill">Vetiver</span>
            <span class="note-pill">Tonka Bean</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
